{
  "framework": null,
  "functions": {
    "api/api.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/api.php",
      "dest": "api/api.php"
    },
    {
      "src": "/api/api.php",
      "dest": "api/api.php"
    },
    {
      "src": "/(.*)",
      "dest": "$1"
    }
  ]
}
